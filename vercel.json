{
  "rewrites": [
    {
      "source": "/portal",
      "destination": "/index.html"
    },
    {
      "source": "/portal/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/form",
      "destination": "/index.html"
    },
    {
      "source": "/form/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/sala/(.*)",
      "destination": "/sala/index.html"
    },
    {
      "source": "/responder/(.*)",
      "destination": "/responder/index.html"
    },
    {
      "source": "/fichar",
      "destination": "/fichar/index.html"
    },
    {
      "source": "/fichar/(.*)",
      "destination": "/fichar/index.html"
    },
    {
      "source": "/f",
      "destination": "/f/index.html"
    },
    {
      "source": "/firmar",
      "destination": "/firmar/index.html"
    },
    {
      "source": "/firmar/(.*)",
      "destination": "/firmar/index.html"
    },
    {
      "source": "/verificar",
      "destination": "/verificar/index.html"
    },
    {
      "source": "/verificar/(.*)",
      "destination": "/verificar/index.html"
    },
    {
      "source": "/propuesta",
      "destination": "/propuesta/index.html"
    },
    {
      "source": "/propuesta/(.*)",
      "destination": "/propuesta/index.html"
    },
    {
      "source": "/contratacion",
      "destination": "/contratacion/index.html"
    },
    {
      "source": "/contratacion/(.*)",
      "destination": "/contratacion/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}